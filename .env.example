# Phase 1 local baseline
# Copy this file to .env before starting local services.

# ------------------------------------------------------------------------------
# Core app URLs
# ------------------------------------------------------------------------------
APP_ENV=local
APP_HOST=localhost
APP_PORT=3000
APP_URL=http://localhost:3000

DIRECTUS_HOST=localhost
DIRECTUS_PORT=8055
DIRECTUS_PUBLIC_URL=http://localhost:8055

# ------------------------------------------------------------------------------
# Directus bootstrap
# ------------------------------------------------------------------------------
DIRECTUS_KEY=replace-with-long-random-string
DIRECTUS_SECRET=replace-with-long-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=replace-with-strong-password
DIRECTUS_ACCEPT_TERMS=true
DIRECTUS_TELEMETRY=false

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=fargespace
POSTGRES_USER=fargespace
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_SSL_MODE=disable

# ------------------------------------------------------------------------------
# Storage
# Local development uses mounted local storage. Reserve S3-compatible values now
# for later staging/production parity.
# ------------------------------------------------------------------------------
DIRECTUS_STORAGE_DRIVER=local
DIRECTUS_STORAGE_ROOT=/directus/uploads

S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ------------------------------------------------------------------------------
# CORS / cookies / auth parity
# ------------------------------------------------------------------------------
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# ------------------------------------------------------------------------------
# Frontend <-> backend integration
# These are reserved now even before the Next.js app exists.
# ------------------------------------------------------------------------------
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
NEXT_PUBLIC_ASSET_BASE_URL=http://localhost:8055/assets

# ------------------------------------------------------------------------------
# Optional outbound email placeholder
# Leave blank in local unless email flows are being tested.
# ------------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
