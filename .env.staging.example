# Vercel frontend
APP_ENV=staging
DIRECTUS_URL=https://your-directus-staging-domain.example.com
DIRECTUS_TOKEN=replace-with-directus-static-token
NEXT_PUBLIC_APP_URL=https://farge-space-think-tank.vercel.app
NEXT_PUBLIC_DIRECTUS_URL=https://your-directus-staging-domain.example.com
NEXT_PUBLIC_ASSET_BASE_URL=https://your-directus-staging-domain.example.com/assets

# Railway Directus service
KEY=replace-with-long-random-string
SECRET=replace-with-long-random-string
PUBLIC_URL=https://your-directus-staging-domain.example.com
PASSWORD_RESET_URL_ALLOW_LIST=https://farge-space-think-tank.vercel.app/reset-password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ACCEPT_TERMS=true
TELEMETRY=false

# Railway PostgreSQL for Directus
DB_CLIENT=pg
DB_HOST=replace-with-railway-pg-host
DB_PORT=5432
DB_DATABASE=railway
DB_USER=postgres
DB_PASSWORD=replace-with-railway-pg-password
DB_SSL=false

# Railway Volume for Directus uploads
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=/directus/uploads

# Frontend session / CORS
CORS_ENABLED=true
CORS_ORIGIN=https://farge-space-think-tank.vercel.app
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

# Optional Directus email for future password reset automation
# Current staging can keep manual reset by leaving these blank.
EMAIL_VERIFY_SETUP=false
EMAIL_TRANSPORT=
EMAIL_FROM=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_IGNORE_TLS=false
EMAIL_SMTP_NAME=
