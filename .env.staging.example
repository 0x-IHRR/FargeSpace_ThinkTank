# Preview frontend
APP_ENV=staging
DIRECTUS_URL=https://your-directus-staging-domain.example.com
DIRECTUS_TOKEN=replace-with-directus-static-token
NEXT_PUBLIC_APP_URL=https://your-preview-domain.vercel.app
NEXT_PUBLIC_DIRECTUS_URL=https://your-directus-staging-domain.example.com
NEXT_PUBLIC_ASSET_BASE_URL=https://your-directus-staging-domain.example.com/assets

# Directus public URL
DIRECTUS_PUBLIC_URL=https://your-directus-staging-domain.example.com

# Directus bootstrap
DIRECTUS_KEY=replace-with-long-random-string
DIRECTUS_SECRET=replace-with-long-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=replace-with-strong-password
DIRECTUS_ACCEPT_TERMS=true
DIRECTUS_TELEMETRY=false

# Database
POSTGRES_HOST=replace-with-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=fargespace
POSTGRES_USER=fargespace
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_SSL_MODE=require

# Storage
DIRECTUS_STORAGE_DRIVER=s3
DIRECTUS_STORAGE_ROOT=/directus/uploads

S3_BUCKET=replace-with-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://replace-with-s3-endpoint
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_FORCE_PATH_STYLE=true

# Frontend session / cors
CORS_ENABLED=true
CORS_ORIGIN=https://your-preview-domain.vercel.app
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax

# Optional outbound email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
